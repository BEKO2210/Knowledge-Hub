# ~/.config/knowledge-mcp/env  — chmod 600!
# base64-kodierter 32-Byte-Schlüssel für den Vault (AES-256-GCM)
VAULT_KEY=<base64-32-bytes>
# langer Zufalls-Token — schützt den gesamten Hub
MCP_TOKEN=<token>
# optional:
# KNOWLEDGE_ROOT=/home/user/graphify-knowledge
# GRAPHIFY_BIN=/home/user/.local/bin/graphify
# VAULT_PATH=/home/user/knowledge-mcp/vault.enc
