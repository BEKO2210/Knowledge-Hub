# ~/.config/knowledge-mcp/env  — chmod 600!
# Alle vom Hub gelesenen Umgebungsvariablen. Der Setup-Wizard schreibt die
# ersten drei automatisch; alles andere ist optional und hat funktionierende
# Defaults. Im Docker-Image sind die Pfade bereits auf /data voreingestellt.

# --- Secrets (werden vom Setup-Wizard erzeugt) -------------------------------
# base64-kodierter 32-Byte-Schlüssel für den Vault (AES-256-GCM)
VAULT_KEY=<base64-32-bytes>
# langer Zufalls-Token — schützt den gesamten Hub (Bearer + MCP)
MCP_TOKEN=<token>
# Zugangspasswort für Login/OAuth-Consent (Klartext nur hier, sonst Vault-gewrappt)
OAUTH_PASSWORD=<passwort>

# --- Server ------------------------------------------------------------------
# KNOWLEDGE_HOST=127.0.0.1          # Bind-Adresse (im Container: 0.0.0.0)
# KNOWLEDGE_PORT=8300               # Port (Healthcheck/Compose erwarten 8300)
# OAUTH_ISSUER=https://hub.example  # Issuer-URL; Default: server.public_url aus config.yaml
# TRUSTED_PROXIES=10.0.0.0/8,1.2.3.4  # Proxys, deren Client-IP-Header vertraut wird
                                     # (kommagetrennt, CIDR/IP; Default leer = NIEMAND)

# --- Pfade -------------------------------------------------------------------
# KNOWLEDGE_CONFIG=~/.config/knowledge-mcp/config.yaml
# KNOWLEDGE_ROOT=~/graphify-knowledge        # Wissensgraphen je Projekt
# KMCP_NOTES_ROOT=~/knowledge-notes          # Notizen (MCP/UI) — im Volume halten!
# VAULT_PATH=~/knowledge-mcp/vault.enc       # Vault-Datei (audit.log liegt daneben)
# GRAPHIFY_BIN=~/.local/bin/graphify         # Extraktor-Binary (pip: /usr/local/bin)
# GRAPHIFY_SYNC=~/.local/bin/graphify-sync   # Sync-Skript (tools/graphify-sync)

# --- Backup ------------------------------------------------------------------
# BACKUP_PASSPHRASE=<passphrase>   # verschlüsselt .khub-Backups (sonst Abfrage)

# --- Interna/Overrides (normalerweise ungesetzt lassen) ----------------------
# KMCP_DATA_DIR=<repo-root>        # Zustand: ratelimit.json, oauth_state.json, build-logs
# KMCP_ENV_FILE=~/.config/knowledge-mcp/env  # diese Datei (Entrypoint/Backup)
# KMCP_CONFIG_DIR=~/.config/knowledge-mcp    # Basis für env/config-Defaults
# KMCP_CACHE_DIR=<siehe Code>      # Semantik-Chunk-Index (semantic.py/backup.py)
# KMCP_LOCK_DIR=~/hub-data/locks   # Sperrdateien (Python + Shell müssen matchen)
# GRAPHIFY_BENCH_DIR=~/graphify-bench        # Benchmark-Rohdaten (public_data)
# SYNC_LOCK_WAIT=120               # Sekunden Wartezeit auf die Sync-Sperre
