#!/usr/bin/env python3
"""graphify cluster-only mit force=True — über die offizielle Bibliotheks-API.

graphifys Schwund-Schutz verweigert das Schreiben der geclusterten graph.json,
wenn die Fuzzy-Deduplikation Knoten verschmilzt (neu < alt). Die eigene
Fehlermeldung empfiehlt »pass force=True« — der CLI-Pfad von cluster-only
verdrahtet den Schalter aber nicht (cli.py ruft to_json ohne force auf).

In UNSERER Pipeline ist der Schwund verifiziert legitim: extraction.py ist die
Quelle der Wahrheit, der Dedup läuft auf einer frischen, vollständigen Generation,
und Snapshot + Abnahme-Gate (buildmeta, hub-audit Runs 7/8) schützen vor echtem
Datenverlust. Ohne force entstehen Misch-Generationen: graph.json ohne Communities
neben Report/Viewer einer anderen Zählung (asto-finance, hub-audit Run 10).

Wir ersetzen deshalb graphify.export.to_json prozesslokal durch eine
force-Variante und rufen dann die unveränderte offizielle CLI auf.
"""

from __future__ import annotations

import functools
import os
import runpy
import shutil
import sys


def _importiere_export():
    """Importiert graphify.export — notfalls über das Python der graphify-Installation.

    Der Hub läuft meist mit dem System-Python (oder einer eigenen venv), graphify
    selbst aber in einer pipx-/pip---user-Installation. Deren Interpreter steht im
    Shebang des graphify-Einstiegspunkts — darüber finden wir ihn ohne hartkodierte
    Pfade und starten dieses Skript damit einmalig neu.
    """
    try:
        import graphify.export as export

        return export
    except ModuleNotFoundError:
        if os.environ.get("_GRAPHIFY_CF_REEXEC") == "1":
            raise  # schon einmal neu gestartet — dann ist graphify wirklich nicht da
        graphify_bin = shutil.which("graphify") or os.path.expanduser("~/.local/bin/graphify")
        try:
            with open(graphify_bin, "rb") as f:
                shebang = f.readline().decode("utf-8", "replace").strip()
        except OSError as e:
            raise ModuleNotFoundError(
                f"graphify nicht gefunden ({e}) — Installation: pipx install graphifyy"
            ) from e
        if not shebang.startswith("#!"):
            raise ModuleNotFoundError(f"{graphify_bin} ohne Shebang — graphify-Interpreter unbekannt")
        os.environ["_GRAPHIFY_CF_REEXEC"] = "1"
        # execv-Argumentliste MUSS mit dem Interpreter selbst (argv[0] = Programmname)
        # beginnen, dann folgt das auszuführende Skript. Fehlte der Interpreter als
        # argv[0], interpretierte Python das erste Folgeargument (den Projektpfad) als
        # Skript und brach mit „can't find '__main__' module in <projektpfad>" ab —
        # der Nachtlauf scheiterte dann an jedem Projekt, sobald `env python3` ein
        # graphify-loses Python traf (systemd-PATH-abhängig).
        interp = shebang[2:].split()[0]
        os.execv(interp, [interp, os.path.abspath(sys.argv[0]), *sys.argv[1:]])
        raise AssertionError("unreachable")  # execv kehrt nicht zurück


export = _importiere_export()

export.to_json = functools.partial(export.to_json, force=True)

sys.argv = ["graphify", "cluster-only", *sys.argv[1:]]
runpy.run_module("graphify", run_name="__main__")
