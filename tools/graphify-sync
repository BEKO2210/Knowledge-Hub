#!/usr/bin/env bash
# Sync eines Projekt-graphify-out/ in das private Wissens-Repo (+ Push, best effort).
#
# Run 9 (hub-audit): globale Sync-Sperre — genau EIN Sync arbeitet gleichzeitig im
# Wissens-Repo (rsync + git). Am 14.07. kollidierten parallele Syncs und die echten
# Push-Fehler waren unterdrückt; der Fehlertext behauptete fälschlich, das Repo
# existiere nicht. Jetzt: flock + der ECHTE git-Fehler in der Ausgabe.
# (Die Aufholstrategie für den Push-Rückstau/non-fast-forward ist Run 13.)
set -euo pipefail
PROJECT="${1:?usage: graphify-sync <project-path>}"
PROJECT="$(cd "$PROJECT" && pwd)"
NAME="$(basename "$PROJECT" | tr '[:upper:]' '[:lower:]')"
REPO="$HOME/graphify-knowledge"
SRC="$PROJECT/graphify-out"
[ -d "$SRC" ] || { echo "no graphify-out in $PROJECT — run /graphify first"; exit 1; }

LOCKDIR="${KMCP_LOCK_DIR:-$HOME/hub-data/locks}"
mkdir -p "$LOCKDIR"
SYNC_LOCK_WAIT="${SYNC_LOCK_WAIT:-120}"
exec 9>"$LOCKDIR/sync-repo.lock"
if ! flock -w "$SYNC_LOCK_WAIT" 9; then
  echo "sync ABGEBROCHEN: Wissens-Repo seit ${SYNC_LOCK_WAIT}s gesperrt (anderer Sync läuft): $NAME"
  exit 75
fi

mkdir -p "$REPO/$NAME"
rsync -a --delete "$SRC/" "$REPO/$NAME/graphify-out/"
cd "$REPO"
git add -A
if git diff --cached --quiet; then
  echo "SYNC project=$NAME local=succeeded remote=skipped detail=keine-aenderung"
  exit 0
fi
git commit -q -m "graphify sync: $NAME ($(date -u +%Y-%m-%dT%H:%MZ))"

# Remote-Push mit Selbstheilung (SYNC_CONTRACT, hub-audit Run 13):
# backup.py pusht hub-backups über einen eigenen Klon in dasselbe Repo — origin läuft
# uns damit regelmäßig davon (non-fast-forward). Heilung: fetch + rebase; bei Konflikt
# an Graph-Dateien gewinnt UNSERE frisch abgenommene Generation (-X theirs beim Rebase
# = die eigenen, neu aufgespielten Commits; im Sandbox-Test bewiesen). Scheitert der
# Rebase, wird er abgebrochen: lokaler Stand bleibt intakt, Status ehrlich degraded —
# der nächste Sync versucht es erneut. Der lokale Sync (Hub liest von hier) ist damit
# NIE vom Remote-Zustand abhängig.
push_versuch() { git push -q origin main 2>&1; }
if FEHLER=$(push_versuch); then
  echo "SYNC project=$NAME local=succeeded remote=succeeded detail=pushed"
elif timeout 60 git fetch -q origin && git rebase -q -X theirs origin/main 2>/dev/null; then
  if FEHLER=$(push_versuch); then
    echo "SYNC project=$NAME local=succeeded remote=succeeded detail=pushed-nach-rebase"
  else
    echo "SYNC project=$NAME local=succeeded remote=optional_failed detail=$(echo "$FEHLER" | grep -m1 -oE '(\[rejected\].*|fatal:.*|error:.*)' | tr ' ' '_' | head -c120)"
  fi
else
  git rebase --abort 2>/dev/null || true
  echo "SYNC project=$NAME local=succeeded remote=optional_failed detail=rebase-konflikt-abgebrochen-naechster-lauf-versucht-erneut"
fi
